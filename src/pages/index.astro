---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Finlence | Accounting & Business Consulting">
  <!-- Hero Section -->
  <section class="relative bg-primary min-h-[650px] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark via-primary to-primary-light"></div>
    <!-- Pattern overlay -->
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <!-- Decorative shapes -->
    <div class="absolute top-20 right-10 w-72 h-72 bg-secondary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-primary-light/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-3xl animate-fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full mb-6">
          <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"></span>
          <span class="text-secondary font-medium text-sm tracking-wider uppercase">Welcome to Finlence</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6 font-serif">
          Bridging Your Business to <span class="text-secondary">Financial Success</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed max-w-2xl">
          Expert accounting, taxation, and business consulting services. We help businesses navigate complex financial landscapes with confidence and clarity.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="group px-8 py-4 bg-secondary text-white font-semibold rounded-xl hover:bg-secondary-light transition-all hover:shadow-lg hover:shadow-secondary/25">
            Get Free Consultation
            <svg class="inline-block w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/services" class="px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/10 transition-all backdrop-blur-sm">
            Our Services
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60V30C240 0 480 0 720 30C960 60 1200 60 1440 30V60H0Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { number: '500+', label: 'Clients Served', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
          { number: '15+', label: 'Years Experience', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
          { number: '50+', label: 'Expert Team', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
          { number: '98%', label: 'Client Satisfaction', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
        ].map((stat) => (
          <div class="text-center group scroll-animate">
            <div class="w-14 h-14 bg-accent rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-secondary/10 transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stat.icon} />
              </svg>
            </div>
            <p class="text-3xl md:text-4xl font-bold text-primary font-serif">{stat.number}</p>
            <p class="text-sm text-gray-500 mt-1 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded-full mb-4">What We Do</span>
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif">Our Services</h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">Comprehensive financial solutions tailored to your business needs</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { title: 'Audit & Assurance', desc: 'External, internal, and forensic audit services to ensure compliance and transparency.', href: '/services/audit-assurance', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
          { title: 'Accounting & Finance', desc: 'Complete accounting, financial reporting, and payroll management solutions.', href: '/services/accounting-finance', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
          { title: 'Taxation', desc: 'Corporate tax, VAT, excise tax, and international taxation advisory.', href: '/services/taxation', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z' },
          { title: 'Banking Operations', desc: 'Retail banking, corporate banking, risk management, and digital banking consulting.', href: '/services/banking-operations', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
          { title: 'Regulatory & Compliance', desc: 'AML compliance and outsourced compliance officer services.', href: '/services/regulatory-compliance', icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3' },
          { title: 'Company Formation', desc: 'Company incorporation, business setup, valuation, and due diligence.', href: '/services/company-formation', icon: 'M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z' },
        ].map((service) => (
          <a href={service.href} class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 group border border-gray-100 hover:border-secondary/20 scroll-animate hover:-translate-y-1">
            <div class="w-14 h-14 bg-accent rounded-2xl flex items-center justify-center mb-5 group-hover:bg-secondary/10 transition-colors">
              <svg class="w-6 h-6 text-primary group-hover:text-secondary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-primary mb-3 group-hover:text-secondary transition-colors">{service.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{service.desc}</p>
            <span class="inline-flex items-center text-secondary text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              Learn more
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/services" class="inline-flex items-center gap-2 text-primary font-semibold hover:text-secondary transition-colors">
          View All Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded-full mb-4">How We Work</span>
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif">Our Process</h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">A proven 6-step approach to deliver exceptional results</p>
      </div>
      <div class="relative">
        <!-- Connecting line (desktop) -->
        <div class="hidden lg:block absolute top-8 left-[8%] right-[8%] h-0.5 bg-gray-200"></div>

        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-8">
          {[
            { step: '01', title: 'Discovery & Onboarding', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { step: '02', title: 'System Setup & Transition', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
            { step: '03', title: 'Monthly Data Sharing', icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12' },
            { step: '04', title: 'Accounting & Tax', icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
            { step: '05', title: 'Monthly Review', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { step: '06', title: 'MIS Report Submission', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          ].map((item) => (
            <div class="text-center relative scroll-animate group">
              <div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-4 relative z-10 group-hover:bg-secondary transition-colors duration-300 group-hover:shadow-lg group-hover:shadow-secondary/25">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                </svg>
              </div>
              <span class="text-xs text-secondary font-bold tracking-wider">STEP {item.step}</span>
              <h3 class="text-sm font-semibold text-gray-700 mt-1">{item.title}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-24 bg-accent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-animate">
          <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded-full mb-4">Why Choose Us</span>
          <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 font-serif">The Power of Finlence</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            We combine deep industry expertise with personalized service to deliver financial solutions that drive real business growth.
          </p>
          <ul class="space-y-5">
            {[
              { text: 'Experienced team of certified professionals', desc: 'CA, CPA, and CFA certified experts with decades of combined experience' },
              { text: 'Tailored solutions for every business size', desc: 'From startups to enterprises, we customize our approach for you' },
              { text: 'Transparent pricing with no hidden costs', desc: 'Clear, upfront pricing so you know exactly what you\'re paying for' },
              { text: 'Dedicated account manager for each client', desc: 'A single point of contact who understands your business inside out' },
              { text: 'Technology-driven efficient processes', desc: 'Modern tools and automation for faster, more accurate results' },
            ].map((item) => (
              <li class="flex items-start gap-4 group">
                <div class="w-8 h-8 bg-secondary/10 rounded-lg flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-secondary/20 transition-colors">
                  <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <span class="text-gray-800 font-medium">{item.text}</span>
                  <p class="text-gray-500 text-sm mt-0.5">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="scroll-animate">
          <div class="bg-primary rounded-3xl p-10 md:p-14 text-center relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-secondary/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
            <div class="relative">
              <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 font-serif">Ready to Get Started?</h3>
              <p class="text-gray-300 mb-8 leading-relaxed">Book a free consultation with our experts today and discover how we can help.</p>
              <a href="/contact" class="inline-block px-8 py-4 bg-secondary text-white font-semibold rounded-xl hover:bg-secondary-light transition-all hover:shadow-lg hover:shadow-secondary/25">
                Contact Us Now
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded-full mb-4">Testimonials</span>
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif">What Our Clients Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { name: 'Sarah Mitchell', role: 'CEO, TechVision Inc.', text: 'Finlence transformed our financial operations. Their team\'s expertise in corporate tax planning saved us significantly and their proactive approach keeps us ahead of compliance requirements.' },
          { name: 'David Chen', role: 'Founder, HealthFirst', text: 'As a healthcare startup, we needed a partner who understood our industry. Finlence delivered exceptional accounting and regulatory compliance services that let us focus on our core mission.' },
          { name: 'Priya Sharma', role: 'CFO, GlobalTrade Ltd.', text: 'The team at Finlence is simply outstanding. Their attention to detail in our audit processes and their strategic tax advisory have been invaluable to our international operations.' },
        ].map((testimonial) => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 scroll-animate hover:shadow-lg transition-all duration-300">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 leading-relaxed mb-6 italic">"{testimonial.text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-primary">{testimonial.name.split(' ').map(n => n[0]).join('')}</span>
              </div>
              <div>
                <p class="font-semibold text-primary text-sm">{testimonial.name}</p>
                <p class="text-gray-500 text-xs">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 scroll-animate">
        <span class="inline-block px-4 py-1.5 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded-full mb-4">Industries We Serve</span>
        <h2 class="text-3xl md:text-4xl font-bold text-primary font-serif">Expertise Across Sectors</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          { name: 'Technology', href: '/industries/technology', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
          { name: 'Healthcare', href: '/industries/healthcare', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
          { name: 'Education', href: '/industries/education', icon: 'M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z' },
          { name: 'Startups', href: '/industries/startups', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
          { name: 'Manufacturing', href: '/industries/manufacturing', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z' },
          { name: 'Financial Services', href: '/industries/financial-services', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
