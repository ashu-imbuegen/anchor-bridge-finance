---
import Layout from '../layouts/Layout.astro'

const posts = [
  { title: 'Understanding Corporate Tax: A Complete Guide', excerpt: 'Everything you need to know about corporate tax frameworks, exemptions, and compliance requirements for businesses.', date: 'Mar 28, 2026', category: 'Taxation', slug: '#' },
  { title: 'Why Every Business Needs an Internal Audit', excerpt: 'Discover how internal audits can improve operational efficiency, manage risk, and strengthen governance in your organization.', date: 'Mar 20, 2026', category: 'Audit', slug: '#' },
  { title: 'Choosing the Right Business Structure for Your Company', excerpt: 'A comprehensive comparison of different business structures to help you make the right choice for your venture.', date: 'Mar 15, 2026', category: 'Business Setup', slug: '#' },
  { title: 'VAT Compliance Checklist for Businesses', excerpt: 'Essential steps every business must follow to ensure VAT compliance and avoid penalties from tax authorities.', date: 'Mar 10, 2026', category: 'Taxation', slug: '#' },
  { title: 'The Importance of AML Compliance for Businesses', excerpt: 'How Anti-Money Laundering regulations impact your business and what you need to do to stay compliant.', date: 'Mar 5, 2026', category: 'Compliance', slug: '#' },
  { title: 'How to Choose the Right Accounting Partner', excerpt: 'Key factors to consider when selecting an accounting firm for your business, from expertise to technology and pricing.', date: 'Feb 28, 2026', category: 'Accounting', slug: '#' },
  { title: 'Transfer Pricing: What Businesses Need to Know', excerpt: 'An overview of transfer pricing regulations, documentation requirements, and best practices for multinational companies.', date: 'Feb 20, 2026', category: 'Taxation', slug: '#' },
  { title: 'Business Valuation Methods Explained', excerpt: 'Understanding different valuation approaches and when to use them for mergers, acquisitions, or investment decisions.', date: 'Feb 15, 2026', category: 'Consulting', slug: '#' },
  { title: 'Payroll Management Best Practices for Companies', excerpt: 'Streamline your payroll process with these essential tips covering compliance, benefits administration, and more.', date: 'Feb 10, 2026', category: 'HR', slug: '#' },
]

const categories = ['All', 'Taxation', 'Audit', 'Business Setup', 'Compliance', 'Accounting', 'Consulting', 'HR']
---

<Layout title="Blog & Insights | Finlance">
  <!-- Hero -->
  <section class="bg-primary py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-3">Insights</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Blog & Insights</h1>
      <p class="text-gray-300 text-lg max-w-3xl leading-relaxed">
        Stay informed with the latest insights on accounting, taxation, compliance, and business consulting.
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 py-4 overflow-x-auto">
        {categories.map((cat, i) => (
          <button class:list={[
            'px-4 py-2 text-sm font-medium rounded-full whitespace-nowrap transition-colors',
            i === 0 ? 'bg-primary text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200',
          ]}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Featured Post -->
      <a href={posts[0].slug} class="block bg-primary rounded-2xl p-8 md:p-12 mb-12 group">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 bg-secondary/20 text-secondary text-xs font-medium rounded-full mb-4">{posts[0].category}</span>
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 group-hover:text-secondary transition-colors">{posts[0].title}</h2>
          <p class="text-gray-300 leading-relaxed mb-4">{posts[0].excerpt}</p>
          <span class="text-gray-400 text-sm">{posts[0].date}</span>
        </div>
      </a>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.slice(1).map((post) => (
          <a href={post.slug} class="bg-gray-50 rounded-xl overflow-hidden border border-gray-100 hover:shadow-md transition-shadow group">
            <div class="h-48 bg-gray-200 flex items-center justify-center">
              <span class="text-gray-400 text-sm">Blog Image</span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-accent text-primary text-xs font-medium rounded-full">{post.category}</span>
                <span class="text-gray-400 text-xs">{post.date}</span>
              </div>
              <h3 class="text-lg font-semibold text-primary mb-2 group-hover:text-secondary transition-colors">{post.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
