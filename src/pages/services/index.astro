---
import Layout from '../../layouts/Layout.astro'

const services = [
  { title: 'Audit & Assurance', desc: 'External, internal, and forensic audit services to ensure compliance and transparency.', icon: '🔍', href: '/services/audit-assurance' },
  { title: 'Accounting & Finance', desc: 'Complete accounting, financial reporting, payroll management, and fixed asset management.', icon: '📊', href: '/services/accounting-finance' },
  { title: 'Taxation', desc: 'Corporate tax, VAT, excise tax, international taxation, and transfer pricing advisory.', icon: '📋', href: '/services/taxation' },
  { title: 'Banking Operations', desc: 'Retail banking, corporate banking, risk management, digital banking, and customer services.', icon: '🏦', href: '/services/banking-operations' },
  { title: 'Regulatory & Compliance', desc: 'AML compliance and outsourced compliance officer services for regulated entities.', icon: '⚖️', href: '/services/regulatory-compliance' },
  { title: 'Company Formation', desc: 'Mainland and free zone business setup, liquidation, business valuation, and due diligence.', icon: '🏢', href: '/services/company-formation' },
  { title: 'HR Consulting', desc: 'Talent acquisition and recruitment process outsourcing for growing businesses.', icon: '👥', href: '/services/hr-consulting' },
]
---

<Layout title="Our Services | Finlence">
  <section class="bg-primary py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-3">What We Do</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Our Services</h1>
      <p class="text-gray-300 text-lg max-w-3xl leading-relaxed">
        Comprehensive financial solutions tailored to your business needs. From audit to company formation, we've got you covered.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <a href={service.href} class="bg-gray-50 p-8 rounded-xl border border-gray-100 hover:shadow-lg transition-all group">
            <div class="text-4xl mb-4">{service.icon}</div>
            <h3 class="text-xl font-semibold text-primary mb-3 group-hover:text-secondary transition-colors">{service.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-4">{service.desc}</p>
            <span class="text-secondary text-sm font-medium group-hover:underline">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-primary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Not Sure Which Service You Need?</h2>
      <p class="text-gray-300 text-lg mb-8">Book a free consultation and our experts will guide you to the right solution.</p>
      <a href="/contact" class="inline-block px-8 py-3.5 bg-secondary text-white font-semibold rounded-lg hover:bg-secondary-light transition-colors">
        Get Free Consultation
      </a>
    </div>
  </section>
</Layout>
