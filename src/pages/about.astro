---
import Layout from '../layouts/Layout.astro'
---

<Layout title="About Us | Finlance">
  <!-- Hero -->
  <section class="bg-primary py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-3">About Us</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Who We Are</h1>
      <p class="text-gray-300 text-lg max-w-3xl leading-relaxed">
        Finlance is a leading accounting and business consulting firm dedicated to helping businesses achieve financial excellence.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-2">Our Story</p>
          <h2 class="text-3xl font-bold text-primary mb-6">Building Bridges to Financial Success</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Founded with a vision to bridge the gap between businesses and their financial goals, Finlance has grown into a trusted partner for companies across diverse industries.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Our team of seasoned professionals brings together decades of experience in accounting, taxation, audit, and business consulting. We understand that every business is unique, and we tailor our services to meet your specific needs.
          </p>
          <p class="text-gray-600 leading-relaxed">
            From startups to established enterprises, we provide the financial expertise and strategic guidance needed to navigate today's complex business landscape with confidence.
          </p>
        </div>
        <div class="bg-accent rounded-2xl p-12">
          <div class="grid grid-cols-2 gap-8">
            <div class="text-center">
              <p class="text-4xl font-bold text-primary">500+</p>
              <p class="text-sm text-gray-500 mt-1">Clients Served</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-primary">15+</p>
              <p class="text-sm text-gray-500 mt-1">Years Experience</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-primary">50+</p>
              <p class="text-sm text-gray-500 mt-1">Expert Team</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-primary">7+</p>
              <p class="text-sm text-gray-500 mt-1">Industries Covered</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-10 border border-gray-100">
          <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-primary mb-4">Our Mission</h3>
          <p class="text-gray-600 leading-relaxed">
            To empower businesses with expert financial services and strategic consulting that drives sustainable growth, ensures compliance, and builds lasting value for our clients and their stakeholders.
          </p>
        </div>
        <div class="bg-white rounded-xl p-10 border border-gray-100">
          <div class="w-14 h-14 bg-secondary rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-primary mb-4">Our Vision</h3>
          <p class="text-gray-600 leading-relaxed">
            To be the most trusted financial consulting partner, recognized for our integrity, innovation, and commitment to helping businesses bridge the gap between where they are and where they aspire to be.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-2">What We Believe</p>
        <h2 class="text-3xl md:text-4xl font-bold text-primary">Our Core Values</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { title: 'Integrity', desc: 'We uphold the highest ethical standards in everything we do, ensuring transparency and trust.', icon: '🛡️' },
          { title: 'Excellence', desc: 'We strive for excellence in every engagement, delivering quality that exceeds expectations.', icon: '⭐' },
          { title: 'Innovation', desc: 'We leverage technology and modern practices to provide efficient, forward-thinking solutions.', icon: '💡' },
          { title: 'Partnership', desc: 'We build lasting relationships with our clients, growing together as true business partners.', icon: '🤝' },
        ].map((value) => (
          <div class="text-center p-6">
            <div class="text-4xl mb-4">{value.icon}</div>
            <h3 class="text-lg font-semibold text-primary mb-3">{value.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section id="team" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-secondary font-medium text-sm uppercase tracking-wider mb-2">Our Leadership</p>
        <h2 class="text-3xl md:text-4xl font-bold text-primary">Meet the Team</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { name: 'John Doe', role: 'CEO & Founder', desc: 'Over 20 years of experience in financial consulting and business strategy.' },
          { name: 'Jane Smith', role: 'Head of Audit', desc: 'Chartered Accountant with expertise in external and forensic auditing.' },
          { name: 'Michael Chen', role: 'Head of Taxation', desc: 'Tax specialist with deep knowledge of corporate and international tax frameworks.' },
          { name: 'Sarah Johnson', role: 'Head of Compliance', desc: 'AML compliance expert with a strong regulatory and risk management background.' },
          { name: 'David Williams', role: 'Head of Accounting', desc: 'Expert in financial reporting, management accounting, and payroll services.' },
          { name: 'Emily Brown', role: 'Head of Business Development', desc: 'Drives growth through strategic partnerships and client relationship management.' },
        ].map((member) => (
          <div class="bg-white rounded-xl p-8 border border-gray-100 text-center">
            <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-primary">{member.name.split(' ').map(n => n[0]).join('')}</span>
            </div>
            <h3 class="text-lg font-semibold text-primary">{member.name}</h3>
            <p class="text-secondary text-sm font-medium mb-3">{member.role}</p>
            <p class="text-gray-500 text-sm">{member.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-primary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">Ready to Work With Us?</h2>
      <p class="text-gray-300 text-lg mb-8">Let's discuss how we can help your business grow.</p>
      <a href="/contact" class="inline-block px-8 py-3.5 bg-secondary text-white font-semibold rounded-lg hover:bg-secondary-light transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
